{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=notism_db;Username=mac;Password=postgres;Port=5432"
  },
  "AWS": {
    "Region": "ap-northeast-1",
    "AccessKey": "YourAccessKeyHere",
    "SecretKey": "YourSecretKeyHere",
    "PrivateBucketName": "private-notism-storage",
    "PublicBucketName": "public-notism-storage"
  },
  "JwtSettings": {
    "Secret": "a-very-super-secret-key-that-is-long-enough",
    "TokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7,
    "Issuer": "ReminderService",
    "Audience": "ReminderService"
  },
  "Email": {
    "ApiKey": "your-mailersend-api-key-here",
    "FromEmail": "noreply@yourdomain.com",
    "FromName": "Notism"
  },
  "ClientApp": {
    "Url": "http://localhost:4200"
  },
  "GoogleOAuth": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectPath": "/auth/oauth/google/callback"
  },
  "SepaySettings": {
    "WebhookSecret": "your-sepay-webhook-secret-here"
  }
}